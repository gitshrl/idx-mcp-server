# Bind address for the MCP server.
IDX_BIND=127.0.0.1:8080

# SQLite file for API keys + usage.
IDX_SQLITE=./idx.sqlite

# --- Data source: pick ONE ---

# (a) Local Parquet directory for development. If set, takes precedence.
IDX_DATA_DIR=./data

# (b) Cloudflare R2 (read via DuckDB httpfs). Used when IDX_DATA_DIR is unset
#     and all four are present. Bucket is read as r2://$R2_BUCKET.
# R2_ACCOUNT_ID=
# R2_KEY_ID=
# R2_SECRET=
# R2_BUCKET=idx-data

# Logging
RUST_LOG=info
